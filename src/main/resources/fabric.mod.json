{
	"schemaVersion": 1,
	"id": "metis",
	"version": "${version}",
	"name": "Metis",
	"description": "Client-side perception sensor for the MCDS ecosystem — exposes the player's live coordinates and world context via a local HTTP API. Builds on PlayerCoordsAPI by Sukikui (MIT).",
	"authors": [
		"Suppenterrine",
		"Sukikui (original PlayerCoordsAPI)"
	],
	"contact": {
		"homepage": "https://github.com/Suppenterrine/metis",
		"sources": "https://github.com/Suppenterrine/metis.git",
		"issues": "https://github.com/Suppenterrine/metis/issues"
	},
	"license": "MIT",
	"icon": "assets/metis/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"dev.suppenterrine.metis.Metis"
		],
		"client": [
			"dev.suppenterrine.metis.MetisClient"
		]
	},
	"mixins": [
		"metis.mixins.json",
		{
			"config": "metis.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}
